# ============================================================
# SocialPulse — Environment Configuration
# Copy to .env and fill in values. Never commit .env.
# ============================================================

# --- Application ---
SOCIALPULSE_ENV=development
SOCIALPULSE_DB_PATH=data/socialpulse.duckdb
SOCIALPULSE_LOG_LEVEL=INFO

# --- AI Provider ---
# local = HuggingFace (default, free), openai = OpenAI-compatible API
SOCIALPULSE_AI_PROVIDER=local

# --- HuggingFace (local AI) ---
SOCIALPULSE_HF_MODEL_CACHE_DIR=.cache/huggingface
SOCIALPULSE_SENTIMENT_MODEL=cardiffnlp/twitter-roberta-base-sentiment-latest
SOCIALPULSE_TOPIC_MODEL=all-MiniLM-L6-v2

# --- OpenAI (cloud AI, required when AI_PROVIDER=openai) ---
SOCIALPULSE_OPENAI_API_KEY=
SOCIALPULSE_OPENAI_BASE_URL=https://api.openai.com/v1
SOCIALPULSE_OPENAI_MODEL=gpt-4o-mini

# --- Twitter/X API (leave empty for simulation mode) ---
SOCIALPULSE_TWITTER_BEARER_TOKEN=
SOCIALPULSE_TWITTER_API_KEY=
SOCIALPULSE_TWITTER_API_SECRET=

# --- Pipeline tuning ---
SOCIALPULSE_MAX_CRAWL_RESULTS=1000
SOCIALPULSE_CRAWL_TIMEOUT_SECONDS=30
SOCIALPULSE_AI_MAX_RETRIES=3
SOCIALPULSE_GOLD_REBUILD_BATCH_SIZE=10000

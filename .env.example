# ============================================================
# SocialPulse — Environment Configuration
# Copy to .env and fill in values. Never commit .env.
# ============================================================

# --- Application ---
SOCIALPULSE_ENV=development
SOCIALPULSE_DB_PATH=/app/data/socialpulse.duckdb
SOCIALPULSE_LOG_LEVEL=INFO

# --- Twitter/X API (leave empty for mock mode) ---
SOCIALPULSE_TWITTER_BEARER_TOKEN=
SOCIALPULSE_TWITTER_API_KEY=
SOCIALPULSE_TWITTER_API_SECRET=

# --- AI / HuggingFace ---
SOCIALPULSE_HF_MODEL_CACHE_DIR=/app/models
SOCIALPULSE_SENTIMENT_MODEL=cardiffnlp/twitter-roberta-base-sentiment-latest
SOCIALPULSE_TOPIC_MODEL=all-MiniLM-L6-v2

# --- Pipeline tuning ---
SOCIALPULSE_MAX_CRAWL_RESULTS=1000
SOCIALPULSE_CRAWL_TIMEOUT_SECONDS=30
SOCIALPULSE_AI_MAX_RETRIES=3
SOCIALPULSE_GOLD_REBUILD_BATCH_SIZE=10000
